  "tiles": {
    "0": {
      "type": "markdown",
      "content": "## Fraud FAI BREC Isolated Environment Dashboard\n\nThis dashboard displays metrics for the Fraud Admin Interface (FAI) isolated environment application for Staging, Integration and Production environment. For further information on FAI see [here](https://govukverify.atlassian.net/wiki/x/sgE55Q)."
    },
    "82": {
      "title": "Total time",
      "type": "data",
      "subType": "dql-builder-metrics",
      "query": "timeseries { avg(cloud.aws.workspaces.upTimeByAccountIdRegionUserName), value.C = sum(cloud.aws.workspaces.upTimeByAccountIdRegionUserName, scalar: true) }, by: { username }, filter: { matchesValue(aws.account.id, $SelectedAWSAccount) }",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": {
            "label": "Total time",
            "isLabelVisible": true
          },
          "gapPolicy": "connect"
        },
        "autoSelectVisualization": false,
        "unitsOverrides": [
          {
            "identifier": "value.C",
            "unitCategory": "time",
            "baseUnit": "second",
            "displayUnit": null,
            "decimals": 0,
            "suffix": "",
            "delimiter": false,
            "added": 1773829693713
          },
          {
            "identifier": "avg(cloud.aws.workspaces.upTimeByAccountIdRegionUserName)",
            "unitCategory": "time",
            "baseUnit": "second",
            "displayUnit": null,
            "decimals": null,
            "suffix": "",
            "delimiter": false,
            "added": 1774007401163
          }
        ]
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
        "maxResultMegaBytes": 1,
        "defaultSamplingRatio": 10,
        "enableSampling": false
      },
      "queryConfig": {
        "version": 20,
        "subQueries": [
          {
            "id": "C",
            "isEnabled": true,
            "datatype": "metrics",
            "metric": {
              "key": "cloud.aws.workspaces.upTimeByAccountIdRegionUserName",
              "aggregation": "avg"
            },
            "by": ["username"],
            "convertToValue": "Sum",
            "filter": "aws.account.id = $SelectedAWSAccount "
          }
        ]
      },
      "davis": {
        "enabled": false,
        "davisVisualization": { "isAvailable": true }
      }
    },
