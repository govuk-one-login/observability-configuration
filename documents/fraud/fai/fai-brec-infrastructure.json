    "104": {
      "title": "",
      "description": "",
      "type": "data",
      "query": "timeseries \n  users_connected = sum(cloud.aws.workspaces.userConnectedByAccountIdRegionUserName),\n  workspaces_stopped = sum(cloud.aws.workspaces.stoppedByAccountIdRegionUserName),\n  workspaces_unhealthy = sum(cloud.aws.workspaces.unhealthyByAccountIdRegionUserName),\n  by: { username },\n  filter: { aws.account.id == $SelectedAWSAccount }\n| fieldsAdd logged_in = if(arrayMax(users_connected) > 0, 1, else: 0)\n| fieldsAdd active = if(coalesce(arrayMin(workspaces_stopped), 0) == 0, 1, else: 0)\n| fieldsAdd stopped = if(arrayMin(workspaces_stopped) > 0, 1, else: 0)\n| fieldsAdd unhealthy = if(arrayMax(workspaces_unhealthy) > 0, 1, else: 0)\n| summarize\n  `Users connected count` = sum(logged_in),\n  `Active WorkSpace count` = sum(active),\n  `Stopped WorkSpace count` = sum(stopped),\n  `Unhealthy WorkSpace count` = sum(unhealthy)",
      "visualization": "table",
      "visualizationSettings": {
        "table": {
          "colorThresholdTarget": "background",
          "hideColumnsForLargeResults": false,
          "rowDensity": "comfortable",
          "sortBy": [
            {
              "columnId": "[\"Unhealthy WorkSpace count\"]",
              "direction": "descending"
            }
          ],
          "selectedColumnForRowThreshold": "Unhealthy WorkSpace count"
        },
