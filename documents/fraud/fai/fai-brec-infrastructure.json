{
  "version": 21,
  "variables": [
    {
      "version": 2,
      "key": "Environment",
      "type": "csv",
      "visible": true,
      "editable": true,
      "input": "BREC - Build - 693388806234,BREC - Staging - 393786338175,BREC - Integration - 162026158693,BREC - Production - 542892327706",
      "multiple": false,
      "defaultValue": "BREC - Production - 542892327706"
    },
    {
      "version": 2,
      "key": "SelectedAWSAccount",
      "type": "code",
      "visible": false,
      "editable": true,
      "input": "export default async function () {\n  const AWSAccountID = $Environment.replaceAll(\" \", \"\").split(\"-\")[2]\n  return [AWSAccountID]\n}",
      "multiple": false
    }
  ],
  "tiles": {
    "0": {
      "type": "markdown",
      "content": "## Fraud FAI BREC Isolated Environment Dashboard\n\nThis dashboard displays metrics for the Fraud Admin Interface (FAI) isolated environment application for Staging, Integration and Production environment. For further information on FAI see [here](https://govukverify.atlassian.net/wiki/x/sgE55Q)."
    },
    "82": {
      "title": "Total time",
      "type": "data",
      "subType": "dql-builder-metrics",
      "query": "timeseries { avg(cloud.aws.workspaces.upTimeByAccountIdRegionUserName), value.C = sum(cloud.aws.workspaces.upTimeByAccountIdRegionUserName, scalar: true) }, by: { username }, filter: { matchesValue(aws.account.id, $SelectedAWSAccount) }",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect",
          "leftYAxisSettings": {
            "label": "Total seconds",
            "isLabelVisible": true
          }
        },
        "autoSelectVisualization": false,
        "unitsOverrides": [
          {
            "identifier": "value.C",
            "unitCategory": "time",
            "baseUnit": "second",
            "displayUnit": null,
            "decimals": 0,
            "suffix": "",
            "delimiter": false,
            "added": 1773829693713
          },
          {
            "identifier": "avg(cloud.aws.workspaces.upTimeByAccountIdRegionUserName)",
            "unitCategory": "time",
            "baseUnit": "second",
            "displayUnit": null,
            "decimals": null,
            "suffix": "",
            "delimiter": false,
            "added": 1774007401163
          }
        ]
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
        "maxResultMegaBytes": 1,
        "defaultSamplingRatio": 10,
        "enableSampling": false
      },
      "queryConfig": {
        "version": 20,
        "subQueries": [
          {
            "id": "C",
            "isEnabled": true,
            "datatype": "metrics",
            "metric": {
              "key": "cloud.aws.workspaces.upTimeByAccountIdRegionUserName",
              "aggregation": "avg"
            },
            "by": ["username"],
            "convertToValue": "Sum",
            "filter": "aws.account.id = $SelectedAWSAccount "
          }
        ]
      },
      "davis": {
        "enabled": false,
        "davisVisualization": { "isAvailable": true }
      }
    },
    "86": {
      "title": "Workspace Active",
      "type": "data",
      "query": "timeseries stopped = avg(cloud.aws.workspaces.stoppedByAccountIdRegionUserName),\n    by:{username},\n    filter: { aws.account.id == $SelectedAWSAccount }\n| fieldsAdd stopped = coalesce(stopped, array(0))\n| fieldsAdd active = 1-stopped[]",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": { "scale": "log" },
          "fieldMapping": { "leftAxisValues": ["active"] },
          "gapPolicy": "connect"
        },
        "dataMapping": { "displayedFields": ["username"] },
        "autoSelectVisualization": false
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
        "maxResultMegaBytes": 1,
        "defaultSamplingRatio": 10,
        "enableSampling": false
      },
      "davis": {
        "enabled": false,
        "davisVisualization": { "isAvailable": true }
      }
    },
    "88": { "type": "markdown", "content": "## User Metrics" },
    "89": {
      "title": "User Connected",
      "type": "data",
      "subType": "dql-builder-metrics",
      "query": "timeseries { max(cloud.aws.workspaces.userConnectedByAccountIdRegionUserName), value.B = avg(cloud.aws.workspaces.userConnectedByAccountIdRegionUserName, scalar: true) }, by: { username }",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": { "scale": "log" },
          "gapPolicy": "connect"
        },
        "autoSelectVisualization": false
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
        "maxResultMegaBytes": 1,
        "defaultSamplingRatio": 10,
        "enableSampling": false
      },
      "queryConfig": {
        "version": 20,
        "subQueries": [
          {
            "id": "B",
            "isEnabled": true,
            "datatype": "metrics",
            "metric": {
              "key": "cloud.aws.workspaces.userConnectedByAccountIdRegionUserName",
              "aggregation": "max"
            },
            "by": ["username"],
            "convertToValue": "Avg",
            "filter": ""
          }
        ]
      },
      "davis": {
        "enabled": false,
        "davisVisualization": { "isAvailable": true }
      }
    }
  },
